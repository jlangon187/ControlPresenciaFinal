<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivIconoIncidencia"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/ic_launcher_background"
            android:backgroundTint="#FEF3C7"
            android:padding="8dp"
            android:src="@android:drawable/ic_dialog_alert"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#F59E0B" />

        <TextView
            android:id="@+id/tvAsuntoIncidencia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Visita Médica"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/ivIconoIncidencia"
            app:layout_constraintTop_toTopOf="@+id/ivIconoIncidencia" />

        <TextView
            android:id="@+id/tvEmpleadoFecha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:text="Juan Pérez • 24 Feb 2026"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@+id/tvAsuntoIncidencia"
            app:layout_constraintStart_toEndOf="@+id/ivIconoIncidencia"
            app:layout_constraintTop_toBottomOf="@+id/tvAsuntoIncidencia" />

        <TextView
            android:id="@+id/tvDescripcionIncidencia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Tengo que ir al médico especialista a las 10:30, adjuntaré el justificante cuando llegue."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/ivIconoIncidencia"
            app:layout_constraintTop_toBottomOf="@+id/tvEmpleadoFecha" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>