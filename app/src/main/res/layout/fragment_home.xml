<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg"
    android:fillViewport="true"
    tools:context=".ui.home.HomeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="24dp">

        <View
            android:id="@+id/headerBackground"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@color/header_bg"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="50dp"
            android:layout_marginEnd="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Hola,"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/btnLogout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:text="Panel del Trabajador"
            android:textColor="@color/text_header_sub"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvWelcome" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminPanel"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="MODO ADMIN"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:backgroundTint="#EA580C"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_dialog_dialer"
            app:iconSize="14dp"
            app:iconTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvStatus" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginTop="55dp"
            android:layout_marginEnd="16dp"
            android:text="Salir"
            android:textColor="#EF4444"
            app:cornerRadius="20dp"
            app:strokeColor="#EF4444"
            app:strokeWidth="1dp"
            app:icon="@android:drawable/ic_lock_power_off"
            app:iconTint="#EF4444"
            app:iconSize="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAdminDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="170dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@android:drawable/ic_dialog_map"
                        app:tint="#EA580C" />

                    <TextView
                        android:id="@+id/tvAdminDashboardTitle"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:text="Centro de Control"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/ic_launcher_background"
                            android:backgroundTint="#10B981"
                            android:layout_marginEnd="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Conectado con Base de Datos"
                            android:textColor="#10B981"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="#FFF7ED"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#FFEDD5"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_today"
                            app:tint="#EA580C" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sesión iniciada"
                                android:textColor="#9A3412"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvAdminFechaLocal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-- / -- / ----"
                                android:textColor="#C2410C"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#EFF6FF"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Activos Ahora"
                                android:textColor="#3B82F6"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvAdminStatActivos"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="--"
                                android:textColor="#1D4ED8"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#FEF2F2"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ausencias"
                                android:textColor="#EF4444"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvAdminStatAusencias"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="--"
                                android:textColor="#B91C1C"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E2E8F0"
                    android:layout_marginVertical="24dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdminAccion1"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="GESTIONAR FICHAJES"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:backgroundTint="#EA580C"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_manage"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdminAccion2"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="8dp"
                    android:text="VER INCIDENCIAS"
                    android:textColor="#EA580C"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="#EA580C"
                    app:strokeWidth="2dp"
                    app:icon="@android:drawable/ic_menu_info_details"
                    app:iconTint="#EA580C"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdminUbicacion"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="4dp"
                    android:text="UBICACIÓN Y RADIO GPS"
                    android:textColor="#3B82F6"
                    android:textSize="12sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="#BFDBFE"
                    app:strokeWidth="1dp"
                    app:icon="@android:drawable/ic_dialog_map"
                    app:iconGravity="textStart"
                    app:iconTint="#3B82F6" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Versión App"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="v1.0.0"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nivel de Acceso"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total"
                            android:textColor="#10B981"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.constraintlayout.widget.Group
            android:id="@+id/groupTrabajador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="cardFichaje,tvToolsTitle,gridHerramientas,cardMap" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFichaje"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="170dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Registro de Jornada"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEntrada"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:text="ENTRADA"
                        android:textColor="@color/btn_entrada_fg"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/btn_entrada_bg"
                        app:cornerRadius="14dp"
                        app:strokeColor="#A7F3D0"
                        app:strokeWidth="1dp"
                        app:icon="@android:drawable/ic_input_add"
                        app:iconGravity="textTop"
                        app:iconSize="28dp"
                        app:iconTint="@color/btn_entrada_fg" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSalida"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:text="SALIDA"
                        android:textColor="@color/btn_salida_fg"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/btn_salida_bg"
                        app:cornerRadius="14dp"
                        app:strokeColor="#FECACA"
                        app:strokeWidth="1dp"
                        app:icon="@android:drawable/ic_delete"
                        app:iconGravity="textTop"
                        app:iconSize="28dp"
                        app:iconTint="@color/btn_salida_fg" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBarHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvToolsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            android:text="Herramientas"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardFichaje" />

        <LinearLayout
            android:id="@+id/gridHerramientas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@+id/tvToolsTitle">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerHorario"
                android:layout_width="0dp"
                android:layout_height="85dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:paddingHorizontal="4dp"
                app:elevation="4dp"
                android:text="Horario"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:backgroundTint="@color/btn_tool_bg"
                app:cornerRadius="14dp"
                app:strokeColor="#CBD5E1"
                app:strokeWidth="1dp"
                app:icon="@android:drawable/ic_menu_today"
                app:iconGravity="textTop"
                app:iconSize="24dp"
                app:iconTint="#3B82F6" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerHistorial"
                android:layout_width="0dp"
                android:layout_height="85dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:paddingHorizontal="4dp"
                app:elevation="4dp"
                android:text="Historial"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:backgroundTint="@color/btn_tool_bg"
                app:cornerRadius="14dp"
                app:strokeColor="#CBD5E1"
                app:strokeWidth="1dp"
                app:icon="@android:drawable/ic_menu_agenda"
                app:iconGravity="textTop"
                app:iconSize="24dp"
                app:iconTint="@color/btn_tool_icon" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReportarIncidencia"
                android:layout_width="0dp"
                android:layout_height="85dp"
                android:layout_weight="1"
                android:paddingHorizontal="2dp"
                app:elevation="4dp"
                android:text="Incidencias"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:backgroundTint="@color/btn_tool_bg"
                app:cornerRadius="14dp"
                app:strokeColor="#CBD5E1"
                app:strokeWidth="1dp"
                app:icon="@android:drawable/ic_menu_info_details"
                app:iconGravity="textTop"
                app:iconSize="24dp"
                app:iconTint="#F59E0B" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMap"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            app:layout_constraintHeight_min="180dp"
            app:layout_constraintTop_toBottomOf="@+id/gridHerramientas"
            app:layout_constraintBottom_toBottomOf="parent">

            <org.osmdroid.views.MapView
                android:id="@+id/map"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>